{
    "name": "noelpersson/wc-bulk-variations",
    "description": "WooCommerce Bulk Variations Plugin",
    "type": "wordpress-plugin",
    "version": "1.0.0",
    "author": "Noel Persson",
    "license": "GPL-2.0+",
    "minimum-stability": "dev",
    "require": {
        "php": ">=7.2",
        "wordpress": ">=5.0",
        "woocommerce": ">=5.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "wp-phpunit/wp-phpunit": "^6.0",
        "brain/monkey": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "WC_Bulk_Variations\\": "includes/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "optimize-autoloader": true
    }
}
